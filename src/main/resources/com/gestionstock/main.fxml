<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gestionstock.controller.MainController"
            prefHeight="700.0" prefWidth="1000.0" stylesheets="@style.css">
    
    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="200.0">
            <Label text="GESTION STOCK" styleClass="sidebar-title"/>
            <Button fx:id="btnDashboard" text="Tableau de Bord" styleClass="sidebar-btn" onAction="#showDashboardView"/>
            <Button fx:id="btnArticles" text="Articles" styleClass="sidebar-btn" onAction="#showArticlesView"/>
            <Button fx:id="btnFournisseurs" text="Fournisseurs" styleClass="sidebar-btn" onAction="#showFournisseursView"/>
            <Button fx:id="btnMouvements" text="Mouvements" styleClass="sidebar-btn" onAction="#showMouvementsView"/>
            <StackPane>
                <Button fx:id="btnNotifications" text="Alertes &amp; Notifs" styleClass="sidebar-btn" onAction="#showNotificationsView"/>
                <Label fx:id="notifBadge" text="0" visible="false" StackPane.alignment="TOP_RIGHT"
                       style="-fx-background-color:#e74c3c; -fx-text-fill:white; -fx-font-size:11px; -fx-alignment:center; -fx-pref-width:20; -fx-pref-height:20; -fx-background-radius:10; -fx-border-radius:10; -fx-translate-x:10; -fx-translate-y:-10;"/>
            </StackPane>
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="Microprojet 2025/2026" textFill="#585b70" style="-fx-alignment: center;"/>
        </VBox>
    </left>
    
    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-area">
            
            <!-- VIEW: DASHBOARD -->
            <VBox fx:id="viewDashboard" spacing="20.0" visible="true">
                <Label text="Tableau de Bord" styleClass="content-title"/>
                <HBox spacing="20.0">
                    <VBox styleClass="card, card-blue">
                        <Label text="TOTAL ARTICLES" styleClass="card-title"/>
                        <Label fx:id="lblTotalArticles" text="0" styleClass="card-value"/>
                    </VBox>
                    <VBox styleClass="card, card-green">
                        <Label text="FOURNISSEURS" styleClass="card-title"/>
                        <Label fx:id="lblTotalFournisseurs" text="0" styleClass="card-value"/>
                    </VBox>
                    <VBox styleClass="card, card-red">
                        <Label text="ALERTES CRITIQUES" styleClass="card-title"/>
                        <Label fx:id="lblTotalAlertes" text="0" styleClass="card-value"/>
                    </VBox>
                </HBox>
                <Label text="Mouvements récents de stock" style="-fx-text-fill: #b4befe; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
                <TableView fx:id="tblDashboardMouvements" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDashMouvId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colDashMouvDate" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="colDashMouvArticle" text="Article" prefWidth="200"/>
                        <TableColumn fx:id="colDashMouvType" text="Type" prefWidth="100"/>
                        <TableColumn fx:id="colDashMouvQte" text="Quantité" prefWidth="100"/>
                        <TableColumn fx:id="colDashMouvUser" text="Opérateur" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- VIEW: ARTICLES -->
            <HBox fx:id="viewArticles" spacing="20.0" visible="false">
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Articles" styleClass="content-title"/>
                    <TableView fx:id="tblArticles" VBox.vgrow="ALWAYS" onMouseClicked="#onArticleSelected">
                        <columns>
                            <TableColumn fx:id="colArtId" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="colArtNom" text="Désignation" prefWidth="220"/>
                            <TableColumn fx:id="colArtFournisseur" text="Fournisseur(s)" prefWidth="220"/>
                            <TableColumn fx:id="colArtQte" text="Quantité en Stock" prefWidth="130"/>
                            <TableColumn fx:id="colArtSeuil" text="Seuil d'Alerte" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox styleClass="form-container">
                    <Label text="Formulaire Article" styleClass="form-title"/>
                    <Label text="Désignation :" textFill="#bac2de"/>
                    <TextField fx:id="txtArtNom" promptText="Ex: Clavier, Souris..."/>
                    <Label text="Quantité Initiale :" textFill="#bac2de"/>
                    <TextField fx:id="txtArtQte" promptText="Ex: 50"/>
                    <Label text="Seuil d'Alerte :" textFill="#bac2de"/>
                    <TextField fx:id="txtArtSeuil" promptText="Ex: 10"/>
                    <Label text="Fournisseurs existants (sélection multiple) :" textFill="#bac2de"/>
                    <ListView fx:id="lstArticleFournisseurs" prefHeight="120" />
                    <Label text="OU nouveau fournisseur (optionnel) :" textFill="#bac2de"/>
                    <TextField fx:id="txtArtFournNom" promptText="Nom du fournisseur" editable="true"/>
                    <TextField fx:id="txtArtFournContact" promptText="Email ou téléphone" editable="true"/>
                    <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button text="Ajouter" styleClass="btn-primary" onAction="#addArticle"/>
                        <Button text="Modifier" styleClass="btn-secondary" onAction="#updateArticle"/>
                    </HBox>
                    <Button text="Supprimer" styleClass="btn-danger" onAction="#deleteArticle" prefWidth="300"/>
                    <Button text="Vider" styleClass="btn-secondary" onAction="#clearArticleForm" prefWidth="300"/>
                </VBox>
            </HBox>
            
            <!-- VIEW: FOURNISSEURS -->
            <HBox fx:id="viewFournisseurs" spacing="20.0" visible="false">
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <Label text="Gestion des Fournisseurs" styleClass="content-title"/>
                    <TableView fx:id="tblFournisseurs" VBox.vgrow="ALWAYS" onMouseClicked="#onFournisseurSelected">
                        <columns>
                            <TableColumn fx:id="colFournId" text="ID" prefWidth="70"/>
                            <TableColumn fx:id="colFournNom" text="Nom du Fournisseur" prefWidth="220"/>
                            <TableColumn fx:id="colFournContact" text="Contact (Email/Tél)" prefWidth="220"/>
                            <TableColumn fx:id="colFournArticles" text="Articles associés" prefWidth="260"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox styleClass="form-container">
                    <Label text="Formulaire Fournisseur" styleClass="form-title"/>
                    <Label text="Nom :" textFill="#bac2de"/>
                    <TextField fx:id="txtFournNom" promptText="Ex: Dell, HP..." editable="true"/>
                    <Label text="Contact :" textFill="#bac2de"/>
                    <TextField fx:id="txtFournContact" promptText="Ex: contact@dell.com" editable="true"/>
                    <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                        <Button text="Ajouter" styleClass="btn-primary" onAction="#addFournisseur"/>
                        <Button text="Modifier" styleClass="btn-secondary" onAction="#updateFournisseur"/>
                    </HBox>
                    <Button text="Supprimer" styleClass="btn-danger" onAction="#deleteFournisseur" prefWidth="300"/>
                    <Button text="Vider" styleClass="btn-secondary" onAction="#clearFournisseurForm" prefWidth="300"/>
                </VBox>
            </HBox>
            
            <!-- VIEW: MOUVEMENTS -->
            <VBox fx:id="viewMouvements" spacing="20.0" visible="false">
                <Label text="Mouvements de Stock" styleClass="content-title"/>
                <HBox spacing="20.0">
                    <VBox styleClass="form-container" HBox.hgrow="ALWAYS" style="-fx-max-width: 9999;">
                        <Label text="Nouvelle Entrée/Sortie" styleClass="form-title"/>
                        <GridPane hgap="15" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30"/>
                                <ColumnConstraints percentWidth="70"/>
                            </columnConstraints>
                            
                            <Label text="Article :" textFill="#bac2de" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <ComboBox fx:id="cmbMouvArticle" promptText="Choisir un article" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            
                            <Label text="Opérateur (Utilisateur) :" textFill="#bac2de" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <ComboBox fx:id="cmbMouvUtilisateur" promptText="Choisir un opérateur" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            
                            <Label text="Type de Mouvement :" textFill="#bac2de" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <HBox spacing="20" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <fx:define>
                                    <ToggleGroup fx:id="toggleTypeMouvement"/>
                                </fx:define>
                                <RadioButton fx:id="radEntree" text="ENTRÉE" toggleGroup="$toggleTypeMouvement" selected="true"/>
                                <RadioButton fx:id="radSortie" text="SORTIE" toggleGroup="$toggleTypeMouvement"/>
                            </HBox>
                            
                            <Label text="Quantité :" textFill="#bac2de" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="txtMouvQte" promptText="Ex: 10" prefWidth="300" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        </GridPane>
                        <Button text="Enregistrer Mouvement" styleClass="btn-primary" onAction="#saveMouvement" prefWidth="250" style="-fx-margin-top: 15;"/>
                    </VBox>
                </HBox>
                <Label text="Historique des mouvements" style="-fx-text-fill: #b4befe; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TableView fx:id="tblMouvements" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMouvId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colMouvDate" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="colMouvArticle" text="Article" prefWidth="220"/>
                        <TableColumn fx:id="colMouvType" text="Type" prefWidth="100"/>
                        <TableColumn fx:id="colMouvQte" text="Quantité" prefWidth="120"/>
                        <TableColumn fx:id="colMouvUser" text="Opérateur (Utilisateur)" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- VIEW: NOTIFICATIONS -->
            <VBox fx:id="viewNotifications" spacing="20.0" visible="false">
                <Label text="Alertes &amp; Notifications de Stock" styleClass="content-title"/>
                <TableView fx:id="tblNotifications" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNotifId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colNotifMessage" text="Message d'Alerte" prefWidth="480"/>
                        <TableColumn fx:id="colNotifSeuil" text="Seuil critique" prefWidth="120"/>
                        <TableColumn fx:id="colNotifCanal" text="Canal" prefWidth="120"/>
                        <TableColumn fx:id="colNotifArticle" text="Article impacté" prefWidth="200"/>
                    </columns>
                </TableView>
                <!-- bouton supprimé : suppression automatique gérée par le service -->
            </VBox>
            
        </StackPane>
    </center>
</BorderPane>
